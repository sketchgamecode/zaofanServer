# 大宋造反模拟器 — 服务端环境变量模板
# 复制本文件为 .env 并填入真实值
# ⚠️ .env 文件绝对不能提交到 git

# ── Supabase ────────────────────────────────────────────────────────────────
# 在 Supabase 控制台 → Settings → API 中找到
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# service_role key（超级权限，只能在服务端使用，绝不能泄露给前端）
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── 服务端配置 ────────────────────────────────────────────────────────────────
PORT=3001

# 允许跨域的客户端来源（多个用逗号分隔）
# 开发时：http://localhost:5173
# 生产时：https://your-game.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ── 安全配置 ──────────────────────────────────────────────────────────────────
# 管理后台接口的额外签名密钥（随机字符串，用于鉴别管理员请求）
ADMIN_SECRET=change_this_to_a_random_string
